{
  "id": null,
  "uid": "sumbot-overview",
  "title": "SumBot Overview",
  "tags": ["sumbot", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Summary Requests / min",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (result) (rate(sumbot_summary_requests_total[5m])) * 60",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqpm"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "type": "stat",
      "title": "Summary Success Rate",
      "id": 2,
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(sumbot_summary_requests_total{result=\"success\"}[5m])) / clamp_min(sum(rate(sumbot_summary_requests_total[5m])), 0.000001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Prometheus Targets Up",
      "id": 3,
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Summary Latency p50/p95",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(sumbot_summary_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sumbot_summary_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Average Source Messages",
      "id": 5,
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(sumbot_summary_source_messages_sum[5m])) / clamp_min(sum(rate(sumbot_summary_source_messages_count[5m])), 0.000001)",
          "legendFormat": "messages",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Average Rendered Turns",
      "id": 6,
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(sumbot_summary_context_turns_sum[5m])) / clamp_min(sum(rate(sumbot_summary_context_turns_count[5m])), 0.000001)",
          "legendFormat": "turns",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "LLM Requests / min",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (result) (rate(sumbot_llm_requests_total[5m])) * 60",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqpm"},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "LLM Latency p50/p95",
      "id": 8,
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(sumbot_llm_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sumbot_llm_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "LLM Tokens / min",
      "id": 9,
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "expr": "sum by (type) (rate(sumbot_llm_tokens_total[5m])) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Telegram Updates / min",
      "id": 10,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "rate(sumbot_telegram_updates_total[5m]) * 60",
          "legendFormat": "updates",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Feedback / min",
      "id": 11,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "targets": [
        {
          "expr": "sum by (value) (rate(sumbot_feedback_total[5m])) * 60",
          "legendFormat": "{{value}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Positive Feedback Ratio",
      "id": 12,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "targets": [
        {
          "expr": "100 * sum(rate(sumbot_feedback_total{value=\"good\"}[30m])) / clamp_min(sum(rate(sumbot_feedback_total[30m])), 0.000001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Postgres Active Connections",
      "id": 13,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count)",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Redis Memory Used",
      "id": 14,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      }
    }
  ]
}
